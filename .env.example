# Required: your Anthropic API key. Memory Map uses Claude for chat and the
# auto-organizer that turns conversations into pages and connections.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: where Memory Map stores its database, markdown pages, and
# generated credentials. Defaults to ./data relative to where you run the
# server. Use an absolute path if you want it somewhere specific.
# DATA_DIR=/Users/you/memory-map-data

# Optional: HTTP port the server listens on. Default 3001.
# PORT=3001

# Optional: bind to all network interfaces (0.0.0.0) instead of localhost
# only. By default Memory Map only accepts connections from your own machine.
# Set this to "true" if you want other devices on your local network to be
# able to reach it (e.g. your phone). They will still need the API key, but
# the login page will be visible to anyone on the same WiFi. For remote
# access from outside your network, prefer Tailscale or an SSH tunnel.
# BIND_LAN=false
